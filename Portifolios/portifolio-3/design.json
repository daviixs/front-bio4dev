
{
  "theme": "dark",
  "colors": {
    "background": "#0F0F0F",
    "backgroundAlt": "#1A1A1A",
    "textPrimary": "#FFFFFF",
    "textSecondary": "#AAAAAA",
    "highlight": "#C084FC",
    "ctaBackground": "#FFFFFF",
    "ctaText": "#000000",
    "border": "rgba(255,255,255,0.1)",
    "cardBackground": "#1A1A1A",
    "experienceTitle": "#60A5FA"
  },
  "typography": {
    "fontFamily": "Poppins, sans-serif",
    "h1": {
      "size": "3rem",
      "weight": 700,
      "lineHeight": "1.2",
      "letterSpacing": "-0.02em"
    },
    "h2": {
      "size": "2rem",
      "weight": 700,
      "lineHeight": "1.3"
    },
    "h3": {
      "size": "1.25rem",
      "weight": 600
    },
    "body": {
      "size": "1rem",
      "lineHeight": "1.6",
      "weight": 400
    },
    "caption": {
      "size": "0.875rem",
      "weight": 400
    }
  },
  "layout": {
    "maxWidth": "1200px",
    "sectionPadding": "6rem 1.5rem",
    "cardGap": "2rem",
    "grid": "2 columns on desktop, stack on mobile"
  },
  "buttons": {
    "primary": {
      "background": "#FFFFFF",
      "text": "#000000",
      "padding": "0.75rem 1.5rem",
      "borderRadius": "8px",
      "hover": {
        "background": "#E5E5E5"
      }
    },
    "secondary": {
      "background": "transparent",
      "text": "#FFFFFF",
      "border": "2px solid #FFFFFF",
      "borderRadius": "8px"
    }
  },
  "cards": {
    "background": "#1A1A1A",
    "padding": "2rem",
    "borderRadius": "16px",
    "shadow": "0 4px 20px rgba(0,0,0,0.4)",
    "hoverEffect": {
      "transform": "scale(1.02)",
      "shadow": "0 8px 32px rgba(0,0,0,0.5)"
    }
  },
  "icons": {
    "style": "Lucide or Devicon",
    "color": "#FFFFFF",
    "size": "32px"
  },
  "animations": {
    "hoverLift": "translateY(-4px)",
    "fadeIn": {
      "from": "opacity: 0; transform: translateY(20px)",
      "to": "opacity: 1; transform: translateY(0)",
      "duration": "0.6s",
      "easing": "ease-in-out"
    }
  }
}
